# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Airflow ───────────────────────────────────────────────────────────────────
# Set AIRFLOW_HOME to your working directory (default: ~/airflow/)
# export AIRFLOW_HOME=~/airflow
export AIRFLOW__CORE__DAGS_FOLDER=/path/to/news-aggregator/dags
export AIRFLOW__CORE__LOAD_EXAMPLES=False
export AIRFLOW__CORE__EXECUTOR=LocalExecutor
export AIRFLOW__WEBSERVER__EXPOSE_CONFIG=True

# ── NYTimes API ───────────────────────────────────────────────────────────────
# Get your free key at https://developer.nytimes.com/
export NYT_API_KEY=your_nytimes_api_key_here

# ── LLM — pick at least one ──────────────────────────────────────────────────
# Option 1: Anthropic Claude (recommended) — https://console.anthropic.com/
export ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: OpenAI GPT — https://platform.openai.com/api-keys
export OPENAI_API_KEY=your_openai_api_key_here

# Option 3: Ollama (free, local) — install from https://ollama.ai/
#   then run: ollama pull llama3.2
#   No key needed; client auto-detects localhost:11434

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail:   smtp.gmail.com:587  (use an App Password, not your login password)
#   Setup: Google Account → Security → 2-Step Verification → App passwords
# Outlook: smtp-mail.outlook.com:587
export SMTP_HOST=smtp.gmail.com
export SMTP_PORT=587
export SMTP_USER=you@gmail.com
export SMTP_PASSWORD=your_16_char_app_password
export EMAIL_FROM=you@gmail.com
export EMAIL_TO=recipient@example.com,another@example.com
